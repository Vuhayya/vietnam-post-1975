{
  "name": "vnr202-challenge",
  "private": true,
  "version": "0.1.0",
  "description": "VNR202 Challenge - Gameshow hoc tap truc tuyen (Olympia-style)",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "npm run build -w client && npm run start -w server",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
